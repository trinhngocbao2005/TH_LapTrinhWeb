@model WebsiteBanHang.Models.Product
@{
    ViewData["Title"] = "Xóa máy ảnh - " + Model.Name;
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none hover-link small">
        <i class="fa-solid fa-arrow-left me-1"></i> Hủy và trở về danh sách
    </a>
</div>

<div class="max-width-form mx-auto">
    <div class="glass-card p-5 border border-danger">
        <div class="text-center mb-4">
            <div class="fs-1 text-danger mb-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <h2 class="mb-2">Xác nhận xóa máy ảnh?</h2>
            <p class="text-muted small">Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa dòng máy ảnh này khỏi bộ sưu tập của studio?</p>
        </div>

        <div class="glass-card bg-surface p-4 mb-4 d-flex align-items-center gap-4 flex-wrap">
            <div style="width: 120px; aspect-ratio: 4/3; border-radius: var(--radius-sm); overflow: hidden; border: 1px solid var(--border-glass);">
                <img src="@Model.AvatarUrl" alt="@Model.Name" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>
            <div>
                <span class="badge bg-danger mb-2 font-monospace">@ViewBag.CategoryName</span>
                <h4 class="mb-2">@Model.Name</h4>
                <p class="price-tag mb-0">@Model.Price.ToString("N0") <small style="font-size: 0.75rem;">đ</small></p>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <div class="d-flex justify-content-center gap-3 pt-2">
                <a asp-action="Index" class="btn btn-premium-outline px-4">Hủy bỏ</a>
                <button type="submit" class="btn btn-danger px-5 py-2 font-weight-bold" style="border-radius: var(--radius-sm); box-shadow: 0 4px 15px rgba(220, 53, 69, 0.4);">
                    <i class="fa-solid fa-trash me-2"></i> Xác nhận xóa
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .max-width-form {
        max-width: 600px;
    }
</style>
