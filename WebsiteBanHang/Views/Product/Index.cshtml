@model IEnumerable<WebsiteBanHang.Models.Product>
@{
    ViewData["Title"] = "Thế Giới Máy Ảnh Chuyên Nghiệp - Ngọc Bảo Studio";
    var categories = ViewBag.Categories as IEnumerable<WebsiteBanHang.Models.Category>;
    int? selectedCat = ViewBag.SelectedCategoryId as int?;
    string? selectedPrice = ViewBag.SelectedPriceRange as string;
    string? searchString = ViewBag.SearchString as string;
}

<!-- Redesigned Premium Editorial Hero Banner with Integrated Promos -->
<div class="studio-hub-banner-container mb-5">
    <!-- Top Part: Elegant Editorial Header (Centered & Full-Width) -->
    <div class="text-center mb-4">
        <span class="studio-hero-badge">
            <i class="fa-solid fa-crown me-1 text-danger"></i> Ngọc Bảo Studio Premium Edition
        </span>
        <h2 class="hero-main-title mt-3 mb-2">
            Lưu Giữ Khoảnh Khắc <span class="gradient-text">— Định Hình Tuyệt Tác</span>
        </h2>
        <p class="hero-description mx-auto mb-3" style="max-width: 740px;">
            Khám phá hệ sinh thái máy ảnh chuyên nghiệp Full-Frame & Mirrorless thế hệ mới. Đỉnh cao công nghệ cảm biến và thấu kính trứ danh từ các thương hiệu hàng đầu thế giới.
        </p>
        
        <!-- Horizontal Row of Trust Badges - Ultra Sleek & Compact! -->
        <div class="d-flex justify-content-center flex-wrap gap-4 py-2 border-top border-bottom" style="max-width: 740px; margin: 0 auto; border-color: rgba(15, 23, 42, 0.05) !important;">
            <div class="small text-muted d-flex align-items-center" style="font-size: 0.8rem;"><i class="fa-solid fa-circle-check text-success me-2"></i> Cam kết 100% Chính Hãng</div>
            <div class="small text-muted d-flex align-items-center" style="font-size: 0.8rem;"><i class="fa-solid fa-shield-halved text-primary me-2"></i> Bảo Hành 2 Năm Toàn Quốc</div>
            <div class="small text-muted d-flex align-items-center" style="font-size: 0.8rem;"><i class="fa-solid fa-truck-fast text-warning me-2"></i> Giao Hàng Hỏa Tốc</div>
        </div>
    </div>

    <!-- Bottom Part: Two Side-by-side Compact Glass Banners (Sản Phẩm Nổi Bật) integrated neatly -->
    <div class="row g-4 mt-2">
        <div class="col-md-6">
            <a href="#product-catalog-anchor" class="hub-promo-card-link text-decoration-none">
                <div class="hub-promo-card" style="background-image: linear-gradient(135deg, rgba(15, 23, 42, 0.72) 0%, rgba(15, 23, 42, 0.25) 100%), url('/images/products/banner_summer.png');">
                    <div class="hub-promo-badge">HOT DEAL</div>
                    <div class="hub-promo-content">
                        <h4 class="text-white mb-1">Deal Hè Cực Khủng</h4>
                        <p class="text-white text-opacity-85 small mb-0">Giảm đến 30% cho các dòng Fujifilm X-Series nhập khẩu.</p>
                    </div>
                    <div class="hub-promo-arrow"><i class="fa-solid fa-arrow-right-long text-white"></i></div>
                </div>
            </a>
        </div>
        <div class="col-md-6">
            <a href="#product-catalog-anchor" class="hub-promo-card-link text-decoration-none">
                <div class="hub-promo-card" style="background-image: linear-gradient(135deg, rgba(15, 23, 42, 0.72) 0%, rgba(15, 23, 42, 0.25) 100%), url('/images/products/banner_upgrade.png');">
                    <div class="hub-promo-badge bg-primary">TRADE-IN</div>
                    <div class="hub-promo-content">
                        <h4 class="text-white mb-1">Nâng Cấp Sony Alpha</h4>
                        <p class="text-white text-opacity-85 small mb-0">Thu cũ đổi mới, trợ giá lên tới 5.000.000đ toàn quốc.</p>
                    </div>
                    <div class="hub-promo-arrow"><i class="fa-solid fa-arrow-right-long text-white"></i></div>
                </div>
            </a>
        </div>
    </div>
</div>


<!-- Full-Width Layout for Premium Catalog Showcase -->
<div class="row" id="product-catalog-anchor">
    <div class="col-12 d-flex flex-column gap-4">
        
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h3 class="section-heading-decorator mb-0 text-start">Thiết Bị Nhiếp Ảnh</h3>
                <p class="text-muted small mt-2">Bộ sưu tập máy ảnh đỉnh cao chính hãng tại Ngọc Bảo Studio</p>
            </div>
            <div>
                <a asp-action="Create" class="btn btn-premium-primary">
                    <i class="fa-solid fa-plus me-2"></i> Thêm máy ảnh mới
                </a>
            </div>
        </div>

        <!-- Tool Bar: Pill Filters (Category + Price) -->
        <div class="glass-card p-4 d-flex flex-column gap-3">
            <!-- Category Pills -->
            <div class="pill-filter-container align-items-center">
                <span class="text-muted small fw-bold me-2"><i class="fa-solid fa-camera me-1"></i> Dòng máy:</span>
                <a asp-action="Index" asp-route-categoryId="" asp-route-priceRange="@selectedPrice" asp-route-searchString="@searchString" class="pill-filter @(!selectedCat.HasValue ? "active" : "")">Tất cả</a>
                @if (categories != null)
                {
                    foreach (var cat in categories)
                    {
                        <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-priceRange="@selectedPrice" asp-route-searchString="@searchString" class="pill-filter @(selectedCat == cat.Id ? "active" : "")">@cat.Name</a>
                    }
                }
            </div>
            
            <!-- Price Range Pills -->
            <div class="pill-filter-container align-items-center">
                <span class="text-muted small fw-bold me-2"><i class="fa-solid fa-coins me-1"></i> Tầm giá:</span>
                <a asp-action="Index" asp-route-categoryId="@selectedCat" asp-route-priceRange="" asp-route-searchString="@searchString" class="pill-filter @(string.IsNullOrEmpty(selectedPrice) ? "active" : "")">Tất cả mức giá</a>
                <a asp-action="Index" asp-route-categoryId="@selectedCat" asp-route-priceRange="under50m" asp-route-searchString="@searchString" class="pill-filter @(selectedPrice == "under50m" ? "active" : "")">Dưới 50 Triệu</a>
                <a asp-action="Index" asp-route-categoryId="@selectedCat" asp-route-priceRange="50mto80m" asp-route-searchString="@searchString" class="pill-filter @(selectedPrice == "50mto80m" ? "active" : "")">50 - 80 Triệu</a>
                <a asp-action="Index" asp-route-categoryId="@selectedCat" asp-route-priceRange="over80m" asp-route-searchString="@searchString" class="pill-filter @(selectedPrice == "over80m" ? "active" : "")">Trên 80 Triệu</a>
            </div>

            @if (!string.IsNullOrEmpty(searchString))
            {
                <div class="border-top border-secondary pt-2 d-flex justify-content-between align-items-center small">
                    <span class="text-muted">Đang tìm kiếm cho từ khóa: <strong class="text-danger fw-bold">"@searchString"</strong></span>
                    <a asp-action="Index" asp-route-categoryId="@selectedCat" asp-route-priceRange="@selectedPrice" class="text-danger hover-link text-decoration-none">
                        <i class="fa-solid fa-circle-xmark"></i> Xóa tìm kiếm
                    </a>
                </div>
            }
        </div>

        <!-- Products Catalog Grid with Hover Overlays - Spacious 3-Column Layout -->
        @if (!Model.Any())
        {
            <div class="glass-card p-5 text-center my-4">
                <div class="fs-1 text-muted mb-3"><i class="fa-solid fa-camera-slash"></i></div>
                <h4 class="mb-2">Không tìm thấy máy ảnh nào</h4>
                <p class="text-muted small">Không khớp với bộ lọc hoặc từ khóa tìm kiếm đã chọn.</p>
                <a asp-action="Index" class="btn btn-premium-primary mt-3">Hiển thị tất cả máy ảnh</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    var categoryName = categories?.FirstOrDefault(c => c.Id == item.CategoryId)?.Name ?? "Máy ảnh";
                    
                    <div class="col">
                        <div class="product-card-premium d-flex flex-column" data-tilt>
                            <div class="img-wrapper">
                                <span class="category-tag">@categoryName</span>
                                @if (!string.IsNullOrEmpty(item.AvatarUrl))
                                {
                                    <div class="floating-img-container">
                                        <img src="@item.AvatarUrl" alt="@item.Name" loading="lazy" class="floating-camera-img" />
                                        <div class="floating-shadow"></div>
                                    </div>
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-dark text-muted">
                                        <i class="fa-solid fa-image fs-1"></i>
                                    </div>
                                }
                                <!-- Hover Overlay buttons -->
                                <div class="img-overlay">
                                    <div class="overlay-btns-wrapper text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-light btn-sm mb-2 d-block py-2">
                                            <i class="fa-solid fa-eye me-1"></i> Chi tiết máy ảnh
                                        </a>
                                        <button onclick="addToCart(@item.Id)" class="btn btn-premium-primary btn-sm d-block w-100 py-2">
                                            <i class="fa-solid fa-cart-plus me-1"></i> Thêm vào giỏ hàng
                                        </button>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="card-body p-4 d-flex flex-column justify-content-between flex-grow-1">
                                <div>
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title text-truncate mb-0" style="max-width: 75%;" title="@item.Name">@item.Name</h5>
                                        <!-- Star rating simulation -->
                                        <div class="text-warning small fs-7">
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                            <i class="fas fa-star"></i>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3 text-line-clamp">
                                        @(item.Description.Length > 85 ? item.Description.Substring(0, 85) + "..." : item.Description)
                                    </p>
                                </div>
                                
                                <div class="border-top border-secondary pt-3 mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted small">Giá bán chính hãng</span>
                                        <span class="price-tag">@item.Price.ToString("N0") <small style="font-size: 0.75rem;">đ</small></span>
                                    </div>
                                    
                                    <div class="d-flex gap-2">
                                        <!-- Extra actions (Edit/Delete in dynamic app) -->
                                        <a class="btn btn-sm btn-premium-outline flex-grow-1 py-1.5 px-2" asp-action="Edit" asp-route-id="@item.Id">
                                            <i class="fa-solid fa-pen-to-square text-warning me-1"></i> Sửa
                                        </a>
                                        <a class="btn btn-sm btn-premium-outline text-danger py-1.5 px-2.5" asp-action="Delete" asp-route-id="@item.Id" title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Premium Accessories Ecosystem Showcase (Replaces Vertical Sidebar) -->
<div class="mt-5 pt-5">
    <div class="text-center mb-5">
        <span class="studio-hero-badge">Hệ Sinh Thái Studio</span>
        <h3 class="hero-main-title mt-2 fs-2">Phụ Kiện Nhiếp Ảnh Chuyên Nghiệp</h3>
        <p class="text-muted small mx-auto mb-0" style="max-width: 580px;">
            Trang bị trọn vẹn thấu kính, pin sạc và thiết bị phụ trợ tối tân để đồng hành cùng tác phẩm nghệ thuật của bạn.
        </p>
    </div>
    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <a href="#" class="accessory-card-premium text-decoration-none">
                <div class="accessory-glass-body p-4 text-center">
                    <div class="accessory-icon-wrapper mb-3">
                        <i class="fa-solid fa-microchip fs-3"></i>
                    </div>
                    <h5 class="text-primary-theme mb-1">Thẻ nhớ SDXC 128GB</h5>
                    <p class="text-muted small mb-0">Extreme Pro 200MB/s ghi cực nhanh cho 8K RAW</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="#" class="accessory-card-premium text-decoration-none">
                <div class="accessory-glass-body p-4 text-center">
                    <div class="accessory-icon-wrapper mb-3">
                        <i class="fa-solid fa-battery-full fs-3"></i>
                    </div>
                    <h5 class="text-primary-theme mb-1">Pin sạc dự phòng</h5>
                    <p class="text-muted small mb-0">Dòng sạc PD 45W cho máy ảnh hoạt động bền bỉ</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="#" class="accessory-card-premium text-decoration-none">
                <div class="accessory-glass-body p-4 text-center">
                    <div class="accessory-icon-wrapper mb-3">
                        <i class="fa-solid fa-briefcase fs-3"></i>
                    </div>
                    <h5 class="text-primary-theme mb-1">Túi đeo Studio</h5>
                    <p class="text-muted small mb-0">Chống nước tối ưu, lớp đệm bảo vệ ống kính tối tân</p>
                </div>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a href="#" class="accessory-card-premium text-decoration-none">
                <div class="accessory-glass-body p-4 text-center">
                    <div class="accessory-icon-wrapper mb-3">
                        <i class="fa-solid fa-wind fs-3"></i>
                    </div>
                    <h5 class="text-primary-theme mb-1">Bộ vệ sinh ống kính</h5>
                    <p class="text-muted small mb-0">Làm sạch bụi mịn, bảo vệ trọn vẹn thấu kính</p>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .text-line-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 40px;
    }
</style>
